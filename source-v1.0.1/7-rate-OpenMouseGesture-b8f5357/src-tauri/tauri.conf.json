{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GestureHotkeyApp",
  "version": "0.1.0",
  "identifier": "com.ohkat.gesturehotkeyapp",
  "mainBinaryName": "GestureHotkeyApp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GestureHotkeyApp 設定",
        "width": 1300,
        "height": 850,
        "resizable": true,
        "minWidth": 1300,
        "minHeight": 850,
        "center": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "startMenuFolder": "GestureHotkeyApp",
        "installerIcon": "icons/installer-icon.ico"
      }
    }
  }
}
